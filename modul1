import heapq  # library untuk priority queue (antrian prioritas)

# State tujuan (goal state)
GOAL = (1, 2, 3, 4, 5, 6, 7, 8, 0)  # 0 = kotak kosong

# Fungsi heuristic: Manhattan Distance
def get_manhattan_distance(state):
    distance = 0
    for i in range(len(state)):
        value = state[i]
        if value != 0:
            # posisi sekarang
            current_row = i // 3
            current_col = i % 3

            # posisi seharusnya di goal
            # Angka 1 di index 0, Angka 2 di index 1, dst.
            target_row = (value - 1) // 3
            target_col = (value - 1) % 3

            # hitung jarak Manhattan
            distance += abs(current_row - target_row) + abs(current_col - target_col)
    return distance

# Fungsi untuk mencari semua kemungkinan langkah
def get_neighbors(state):
    neighbors = []
    idx = state.index(0)  # cari posisi kosong (0)
    row = idx // 3
    col = idx % 3

    # arah gerakan: atas, bawah, kiri, kanan
    moves = [(-1, 0), (1, 0), (0, -1), (0, 1)]

    for dr, dc in moves:
        nr = row + dr
        nc = col + dc

        # cek apakah masih di dalam grid 3x3
        if 0 <= nr < 3 and 0 <= nc < 3:
            neighbor_list = list(state)
            new_idx = nr * 3 + nc

            # tukar posisi kosong dengan angka di sebelahnya
            neighbor_list[idx], neighbor_list[new_idx] = neighbor_list[new_idx], neighbor_list[idx]
            neighbors.append(tuple(neighbor_list))

    return neighbors  # SEBELUMNYA: Salah karena di dalam loop, SEKARANG: Sudah benar di luar loop

# Fungsi utama A*
def solve_8_puzzle(start_state):
    start_h = get_manhattan_distance(start_state)

    # priority queue berisi (f, g, state, path)
    # f = total cost (g + h), g = jumlah langkah dari awal
    pq = [(start_h, 0, start_state, [])]

    # visited untuk menyimpan biaya terkecil mencapai suatu state
    visited = {start_state: 0}

    while pq:
        # ambil state dengan nilai f terkecil
        f, g, current, path = heapq.heappop(pq)

        # jika sudah sampai goal
        if current == GOAL:
            return path + [current]

        # cek semua kemungkinan langkah dari tetangga
        for neighbor in get_neighbors(current):
            new_g = g + 1

            # jika belum dikunjungi atau menemukan jalur yang lebih murah (g lebih kecil)
            if neighbor not in visited or new_g < visited[neighbor]:
                visited[neighbor] = new_g
                h = get_manhattan_distance(neighbor)
                f_total = new_g + h

                # Masukkan ke antrean prioritas
                heapq.heappush(pq, (f_total, new_g, neighbor, path + [current]))

    return None

# ================== UJI COBA ==================

# Initial state (0 adalah kotak kosong)
initial_state = (1, 2, 3, 4, 0, 6, 7, 5, 8)

print("Mencari solusi dengan A* (Manhattan Distance)...")
steps = solve_8_puzzle(initial_state)

# Tampilkan hasil
if steps:
    print(f"Ditemukan solusi dalam {len(steps)-1} langkah!\n")
    for i, s in enumerate(steps):
        print(f"Langkah {i}:")
        print(f"{s[0]} {s[1]} {s[2]}")
        print(f"{s[3]} {s[4]} {s[5]}")
        print(f"{s[6]} {s[7]} {s[8]}")
        print("-" * 10)
else:
    print("Tidak ditemukan solusi.")





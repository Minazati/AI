from collections import deque

# 1. Fungsi mengecek apakah kondisi aman (Missionaris tidak dimakan)
def constraint(m, c):
    # Cek batas jumlah (tidak boleh < 0 atau > 3)
    if m < 0 or c < 0 or m > 3 or c > 3:
        return False

    # Cek sisi kiri: Jika ada missionaris, jumlahnya tidak boleh kalah dari kanibal
    if m > 0 and m < c:
        return False

    # Cek sisi kanan: (Total 3, jadi kanan = 3 - kiri)
    m_kanan = 3 - m
    c_kanan = 3 - c
    # Jika ada missionaris di kanan, tidak boleh kalah dari kanibal di kanan
    if m_kanan > 0 and m_kanan < c_kanan:
        return False

    return True

# 2. Fungsi BFS untuk mencari jalur terpendek
def bfs_selamatin_missionaris():
    # state = (missionaris_kiri, kanibal_kiri, posisi_perahu)
    initial_state = (3, 3, 'L')
    goal_state = (0, 0, 'R')

    # Antrean menyimpan (state_saat_ini, jalur_yang_sudah_ditempuh)
    queue = deque([(initial_state, [])])
    visited = set()

    while queue:
        (m, c, perahu), path = queue.popleft()

        # Jika sampai target, kembalikan jalurnya
        if (m, c, perahu) == goal_state:
            return path + [(m, c, perahu)]

        if (m, c, perahu) not in visited:
            visited.add((m, c, perahu))

            # Kemungkinan muatan perahu: (M, C) - maksimal 2 orang, minimal 1
            moves = [(2, 0), (0, 2), (1, 1), (1, 0), (0, 1)]

            for dm, dc in moves:
                if perahu == 'L':
                    # Perahu ke kanan: jumlah di kiri berkurang
                    new_state = (m - dm, c - dc, 'R')
                else:
                    # Perahu ke kiri: jumlah di kiri bertambah
                    new_state = (m + dm, c + dc, 'L')

                # Cek apakah langkah baru valid dan belum pernah dikunjungi
                if constraint(new_state[0], new_state[1]):
                    if new_state not in visited:
                        # Masukkan ke antrean, tambahkan state lama ke dalam path
                        queue.append((new_state, path + [(m, c, perahu)]))

    return None

# 3. Bagian Eksekusi
print("=== SOLUSI BFS MISSIONARIES AND CANNIBALS ===")
solusi = bfs_selamatin_missionaris()

if solusi:
    for i, step in enumerate(solusi):
        # Ini akan mencetak: Langkah 0: (3, 3, 'L')
        print(f"Langkah {i}: {step}")
    
    # Ini akan mencetak jumlah total item dalam list solusi
    print(f"Jumlah langkah: {len(solusi)}")
else:
    print("Tidak ditemukan solusi.")

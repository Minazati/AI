from collections import deque

def water_jug_bfs(cap1, cap2, target):
    # 1. Buat antrian (queue)
    queue = deque([(0, 0, [])])
    # 2. Buat set untuk mencatat yang sudah dikunjungi
    visited = set()

    # 3. Selama antrean tidak kosong
    while queue:
        # a. Ambil data dari depan (popleft)
        j1, j2, path = queue.popleft()

        # b. Jika target tercapai
        if j1 == target or j2 == target:
            return path + [(j1, j2)]

        # c. Jika belum dikunjungi
        if (j1, j2) not in visited:
            visited.add((j1, j2))

            # d. Definisikan kemungkinan aksi
            moves = [
                (cap1, j2), (j1, cap2),  # Isi
                (0, j2), (j1, 0),        # Kosongkan
                (j1 - min(j1, cap2 - j2), j2 + min(j1, cap2 - j2)), # Tuang 1 ke 2
                (j1 + min(j2, cap1 - j1), j2 - min(j2, cap1 - j1))  # Tuang 2 ke 1 (KOMA DITAMBAHKAN DI SINI)
            ]

            # e. Masukkan hasil aksi ke belakang antrean
            for m in moves:
                if m not in visited:
                    queue.append((m[0], m[1], path + [(j1, j2)]))

    return None # Pindah ke luar while

# --- EKSEKUSI DI LUAR FUNGSI (Indentasi di nol) ---
print("===SOLUSI BFS (OPSIONAL)===")
solusi_bfs = water_jug_bfs(5, 3, 4)

if solusi_bfs:
    for i, step in enumerate(solusi_bfs): # Perbaikan dari numerate ke enumerate
        print(f"Langkah {i}: {step}")
else:
    print("Tidak ada solusi.")




